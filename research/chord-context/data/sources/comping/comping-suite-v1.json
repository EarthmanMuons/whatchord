      "voicing": "F A B E",
      "expected": {
        "rootPc": 7,
        "quality": "dominant7",
        "extensions": ["nine", "thirteen"]
      },
      "expectedSymbol": "G13 (rootless A form, 7-9-3-13)",
      "pitchSetId": "F-A-B-E"
    },
