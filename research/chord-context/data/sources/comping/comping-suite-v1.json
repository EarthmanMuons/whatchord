{
  "schema": "chord-context-comping-suite/1",
  "title": "Jazz comping suite: rootless and shell voicings",
  "purpose": "Behavioral probes for the Track D gate (rootless/ensemble voicings). Pass/fail probes, excluded from pooled statistics per PROTOCOL.md. Voicings are canonical left-hand comping forms (Levine, The Jazz Theory Book, ch. 3 rootless A/B forms) written as MIDI notes exactly as a pianist would play them over a bassist.",
  "conventions": {
    "intent": "rootless = the chord's root is deliberately absent (a bassist supplies it); shell = guide tones plus optional color, root absent; solo = the same pitch set played with no bassist, where the bass-rooted reading is the correct one",
    "expected": "the identity a musician in that context expects; for rootless cases the root is NOT in midiNotes by design",
    "pairs": "cases sharing a pitchSetId have identical pitch classes and differ only in intent, so the gate's question (can a mode setting decide what the notes cannot) is directly measurable"
  },
  "cases": [
    {
      "id": "rootless-ii-V-I-C-Aform-ii",
      "intent": "rootless",
      "key": "C:maj",
      "midiNotes": [65, 69, 72, 76],
      "voicing": "F A C E",
      "expected": {
        "rootPc": 2,
        "quality": "minor7",
        "extensions": ["nine"]
      },
      "expectedSymbol": "Dm9 (rootless A form, 3-5-7-9)",
      "pitchSetId": "F-A-C-E"
    },
    {
