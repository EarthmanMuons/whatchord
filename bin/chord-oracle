#!/usr/bin/env bash
set -euo pipefail

die() {
	printf "ERROR: %s\n" "$*" >&2
	exit 1
}

repo_root=""
if [[ -n ${GITHUB_WORKSPACE-} ]]; then
	repo_root=$GITHUB_WORKSPACE
else
	if command -v git >/dev/null 2>&1; then
		repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
	fi
fi
[[ -n $repo_root ]] || die "Could not determine repository's top-level directory."

##### MAIN

if [[ -z ${WHATCHORD_CHORD_ORACLE_MISE-} ]] && command -v mise >/dev/null 2>&1; then
	exec env WHATCHORD_CHORD_ORACLE_MISE=1 mise exec -- python "$repo_root/tool/chord/oracle.py" "$@"
fi

exec python3 "$repo_root/tool/chord/oracle.py" "$@"
